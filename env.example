# Slack Incoming Webhook（チャンネルに「着信 Webhook」アプリを追加して取得）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Discord チャンネル設定 → 連携サービス → ウェブフック
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- X に API で投稿する場合（post-x.mjs / Web UI）OAuth 1.0a ---
# X Developer Portal の App で API Key / Secret、User の Access Token / Secret を発行
# X_USERNAME は @ なし（例: elonmusk）
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_USERNAME=

# --- 任意: X API で自動ポーリングする場合（読み取りは有料プランが必要なことが多い）---
# X_BEARER_TOKEN=
# X_USER_ID=

# --- Bluesky（AT Protocol）任意 ---
# Settings → Privacy and Security → App Passwords で発行
# BSKY_HANDLE=yourname.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Threads（Meta Threads API）任意 ---
# Meta for Developers でアプリ作成 → Threads API プロダクト追加 → アクセストークン取得
# THREADS_USER_ID=1234567890
# THREADS_ACCESS_TOKEN=EAA...

# --- Web UI（server.mjs）任意 ---
# RELAY_UI_HOST=127.0.0.1
# RELAY_UI_PORT=3847
# ブラウザから叩くとき用の簡易ガード（未設定なら認証なし）
# RELAY_UI_USER=
# RELAY_UI_PASSWORD=
